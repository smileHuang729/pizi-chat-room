{
  "name": "chat-server",
  "version": "1.0.0",
  "description": "Chat room server with Socket.io",
  "main": "dist/index.js",
  "scripts": {
    "predev": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "dev": "ts-node-dev --respawn --transpile-only --interval 1000 src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
